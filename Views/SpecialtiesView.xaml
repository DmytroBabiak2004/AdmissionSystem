<UserControl x:Class="AdmissionSystem.Views.SpecialtiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ Додати" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                    <Button Content="✏ Редагувати" Style="{StaticResource GrayButton}"
                            Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                    <Button Content="🔄 Активна/Неактивна" Style="{StaticResource GrayButton}"
                            Command="{Binding ToggleActiveCommand}" Margin="0,0,8,0"/>
                    <Button Content="🗑 Видалити" Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Specialties}"
                          SelectedItem="{Binding SelectedSpecialty}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="70"/>
                        <DataGridTextColumn Header="Назва спеціальності" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Факультет" Binding="{Binding Faculty}" Width="220"/>
                        <DataGridTextColumn Header="Бюджет" Binding="{Binding BudgetPlaces}" Width="75"/>
                        <DataGridTextColumn Header="Контракт" Binding="{Binding ContractPlaces}" Width="85"/>
                        <DataGridTemplateColumn Header="Статус" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding IsActive, Converter={StaticResource ActiveToColorConverter}}"
                                            CornerRadius="4" Padding="8,3" Margin="4,2">
                                        <TextBlock Text="{Binding IsActive, Converter={StaticResource ActiveToStringConverter}}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Edit panel -->
        <Border Grid.Column="1"
                Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="380" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Редагування спеціальності"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Код спеціальності *"/>
                    <TextBox Text="{Binding EditingSpecialty.Code, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Назва спеціальності *"/>
                    <TextBox Text="{Binding EditingSpecialty.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Факультет"/>
                    <TextBox Text="{Binding EditingSpecialty.Faculty, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Кількість бюджетних місць"/>
                    <TextBox Text="{Binding EditingSpecialty.BudgetPlaces, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Кількість контрактних місць"/>
                    <TextBox Text="{Binding EditingSpecialty.ContractPlaces, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Опис"/>
                    <TextBox Text="{Binding EditingSpecialty.Description, UpdateSourceTrigger=PropertyChanged}"
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

                    <CheckBox IsChecked="{Binding EditingSpecialty.IsActive}"
                              Content="Активна" Margin="0,0,0,24"
                              FontFamily="Segoe UI" FontSize="13"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Скасувати" Style="{StaticResource GrayButton}"
                                Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                        <Button Content="💾 Зберегти" Style="{StaticResource SuccessButton}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
