<UserControl x:Class="AdmissionSystem.Views.ApplicationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" BasedOn="{StaticResource ActionButton}" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
        </Style>
        <Style x:Key="BtnSecondary" BasedOn="{StaticResource ActionButton}" TargetType="Button">
            <Setter Property="Background" Value="#F2F2F7"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
        </Style>
        <Style x:Key="BtnDanger" BasedOn="{StaticResource ActionButton}" TargetType="Button">
            <Setter Property="Background" Value="#FF3B30"/>
        </Style>
        <Style x:Key="BtnSuccess" BasedOn="{StaticResource ActionButton}" TargetType="Button">
            <Setter Property="Background" Value="#34C759"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="52"/>
            <Setter Property="ColumnHeaderHeight" Value="48"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E5EA"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8E8E93"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E5EA"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F8F8"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="DataGridCenterStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DataGridRightStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="24" Padding="24" Margin="0,0,0,24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.04" Color="#001530"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnPrimary}" Command="{Binding AddCommand}" Margin="0,0,12,0" MinWidth="130">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Додати" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnSecondary}" Command="{Binding EditCommand}" Margin="0,0,12,0" MinWidth="140">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Редагувати" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnSecondary}" Command="{Binding OpenStatusChangeCommand}" Margin="0,0,12,0" MinWidth="130">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Статус" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnDanger}" Command="{Binding DeleteCommand}" MinWidth="130">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Видалити" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1" Background="#F2F2F7" CornerRadius="12" Padding="16,8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Applications.Count, StringFormat=Усього заяв: {0}}"
                               FontSize="14" FontWeight="Bold" Foreground="#1C1C1E"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="24" Padding="0" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.04" Color="#001530"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" ItemsSource="{Binding Applications}" SelectedItem="{Binding SelectedApplication}" IsReadOnly="True" Margin="0,0,0,16">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" ElementStyle="{StaticResource DataGridCenterStyle}"/>
                        <DataGridTextColumn Header="АБІТУРІЄНТ" Binding="{Binding Applicant.FullName}" Width="250">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextStyle}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#1C1C1E"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="СПЕЦІАЛЬНІСТЬ" Binding="{Binding Specialty.Name}" Width="*" ElementStyle="{StaticResource DataGridTextStyle}"/>
                        <DataGridTextColumn Header="ПРІОРИТЕТ" Binding="{Binding Priority}" Width="100" ElementStyle="{StaticResource DataGridCenterStyle}"/>
                        <DataGridTextColumn Header="ФОРМА" Binding="{Binding FormOfEducation, Converter={StaticResource FormToStringConverter}}" Width="120" ElementStyle="{StaticResource DataGridTextStyle}"/>
                        <DataGridTextColumn Header="ОСНОВА" Binding="{Binding EducationBasis, Converter={StaticResource BasisToStringConverter}}" Width="120" ElementStyle="{StaticResource DataGridTextStyle}"/>
                        <DataGridTextColumn Header="БАЛ" Binding="{Binding CompetitiveScore, StringFormat=F1}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridRightStyle}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="СТАТУС" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding CurrentStatus, Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="8" Padding="12,4" Margin="0,0,16,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CurrentStatus, Converter={StaticResource StatusToStringConverter}}"
                                                   Foreground="{Binding CurrentStatus, Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="ДАТА" Binding="{Binding SubmissionDate, StringFormat=dd.MM.yyyy}" Width="110" ElementStyle="{StaticResource DataGridCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Background="#F2F2F7" Padding="24,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Історія змін статусу заяви" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#1C1C1E"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="{Binding StatusHistory.Count, StringFormat=Записів: {0}}"
                                   VerticalAlignment="Center" FontSize="13" FontWeight="Medium" Foreground="#8E8E93"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2" ItemsSource="{Binding StatusHistory}" IsReadOnly="True" RowHeight="48">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ДАТА ТА ЧАС" Binding="{Binding ChangedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150" ElementStyle="{StaticResource DataGridTextStyle}"/>
                        <DataGridTextColumn Header="АВТОР ЗМІНИ" Binding="{Binding ChangedBy}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextStyle}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="БУЛО" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding OldStatus, Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OldStatus, Converter={StaticResource StatusToStringConverter}}"
                                                   Foreground="{Binding OldStatus, Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="СТАЛО" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding NewStatus, Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NewStatus, Converter={StaticResource StatusToStringConverter}}"
                                                   Foreground="{Binding NewStatus, Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="КОМЕНТАР" Binding="{Binding Comment}" Width="*" ElementStyle="{StaticResource DataGridTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding IsStatusChangePanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#B2000000" Panel.ZIndex="20">
            <Border Width="460" Background="#FFFFFF" CornerRadius="24" Padding="32" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="15" Opacity="0.15" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Змінити статус заяви" FontSize="22" FontWeight="Bold" Margin="0,0,0,24" Foreground="#1C1C1E"/>

                    <TextBlock Text="Новий статус" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AllStatuses}" SelectedItem="{Binding NewStatus}" Height="44" Padding="12,0" Margin="0,0,0,20">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Converter={StaticResource StatusToColorConverter}}" CornerRadius="8" Padding="10,4">
                                    <TextBlock Text="{Binding Converter={StaticResource StatusToStringConverter}}"
                                               Foreground="{Binding Converter={StaticResource StatusToForegroundConverter}}"
                                               FontSize="13" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Коментар" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding StatusChangeComment, UpdateSourceTrigger=PropertyChanged}"
                             Height="100" TextWrapping="Wrap" AcceptsReturn="True" Padding="12" Margin="0,0,0,32"
                             FontSize="14" VerticalContentAlignment="Top"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BtnSecondary}" Command="{Binding CancelStatusChangeCommand}" Margin="0,0,12,0" MinWidth="120">
                            <TextBlock Text="Скасувати"/>
                        </Button>
                        <Button Style="{StaticResource BtnPrimary}" Command="{Binding ApplyStatusChangeCommand}" MinWidth="120">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Застосувати" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#B2000000" Panel.ZIndex="20">
            <Border Width="640" Background="#FFFFFF" CornerRadius="24" Padding="32" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="15" Opacity="0.15" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Деталі заяви" FontSize="22" FontWeight="Bold" Margin="0,0,0,24" Foreground="#1C1C1E"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Абітурієнт *" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Applicants}" SelectedValue="{Binding EditingApplication.ApplicantId}"
                                      SelectedValuePath="Id" DisplayMemberPath="FullName" Height="44" Padding="12,0" Margin="0,0,0,20"/>

                            <TextBlock Text="Спеціальність *" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Specialties}" SelectedValue="{Binding EditingApplication.SpecialtyId}"
                                      SelectedValuePath="Id" DisplayMemberPath="Name" Height="44" Padding="12,0" Margin="0,0,0,20"/>

                            <TextBlock Text="Форма навчання" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AllForms}" SelectedItem="{Binding EditingApplication.FormOfEducation}" Height="44" Padding="12,0" Margin="0,0,0,20">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource FormToStringConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Основа навчання" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AllBases}" SelectedItem="{Binding EditingApplication.EducationBasis}" Height="44" Padding="12,0" Margin="0,0,0,20">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource BasisToStringConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Пріоритет *" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditingApplication.Priority, UpdateSourceTrigger=PropertyChanged}" Height="44" Padding="12,0" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                            <TextBlock Text="Конкурсний бал" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditingApplication.CompetitiveScore, UpdateSourceTrigger=PropertyChanged}" Height="44" Padding="12,0" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                            <TextBlock Text="Примітки" Foreground="#8E8E93" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditingApplication.Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="116" TextWrapping="Wrap" AcceptsReturn="True" Padding="12" FontSize="14" VerticalContentAlignment="Top" Margin="0,0,0,20"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Style="{StaticResource BtnSecondary}" Command="{Binding CancelCommand}" Margin="0,0,12,0" MinWidth="120">
                            <TextBlock Text="Скасувати"/>
                        </Button>
                        <Button Style="{StaticResource BtnSuccess}" Command="{Binding SaveCommand}" MinWidth="120">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Зберегти" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>