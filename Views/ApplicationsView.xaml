<UserControl x:Class="AdmissionSystem.Views.ApplicationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Додати заяву" Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                <Button Content="✏ Редагувати" Style="{StaticResource GrayButton}"
                        Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                <Button Content="🔄 Змінити статус" Style="{StaticResource GrayButton}"
                        Command="{Binding OpenStatusChangeCommand}" Margin="0,0,8,0"/>
                <Button Content="🗑 Видалити" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Border>

        <!-- Main DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" ItemsSource="{Binding Applications}"
                          SelectedItem="{Binding SelectedApplication}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Абітурієнт" Binding="{Binding Applicant.FullName}" Width="200"/>
                        <DataGridTextColumn Header="Спеціальність" Binding="{Binding Specialty.Name}" Width="*"/>
                        <DataGridTextColumn Header="Пр-т"
                                            Binding="{Binding Priority}" Width="45"/>
                        <DataGridTextColumn Header="Форма"
                                            Binding="{Binding FormOfEducation,
                                                      Converter={StaticResource FormToStringConverter}}"
                                            Width="85"/>
                        <DataGridTextColumn Header="Основа"
                                            Binding="{Binding EducationBasis,
                                                      Converter={StaticResource BasisToStringConverter}}"
                                            Width="85"/>
                        <DataGridTextColumn Header="Конкурсний бал"
                                            Binding="{Binding CompetitiveScore, StringFormat=F2}"
                                            Width="120"/>
                        <DataGridTemplateColumn Header="Статус" Width="210">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding CurrentStatus,
                                                        Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="4" Padding="8,3" Margin="2">
                                        <TextBlock Text="{Binding CurrentStatus,
                                                          Converter={StaticResource StatusToStringConverter}}"
                                                   Foreground="{Binding CurrentStatus,
                                                                Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding SubmissionDate, StringFormat=dd.MM.yyyy}"
                                            Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- History section header -->
                <Border Grid.Row="1" Background="#E3F2FD" Padding="12,8">
                    <TextBlock Text="Історія змін статусів обраної заяви"
                               FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Border>

                <!-- Status history -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding StatusHistory}"
                          RowBackground="White" AlternatingRowBackground="#F9FBE7"
                          RowHeight="32">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding ChangedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Ким змінено" Binding="{Binding ChangedBy}" Width="150"/>
                        <DataGridTemplateColumn Header="Старий статус" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding OldStatus,
                                                        Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="3" Padding="6,2" Margin="2">
                                        <TextBlock Text="{Binding OldStatus,
                                                          Converter={StaticResource StatusToStringConverter}}"
                                                   FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Новий статус" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding NewStatus,
                                                        Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="3" Padding="6,2" Margin="2">
                                        <TextBlock Text="{Binding NewStatus,
                                                          Converter={StaticResource StatusToStringConverter}}"
                                                   Foreground="{Binding NewStatus,
                                                                Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Коментар" Binding="{Binding Comment}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status change overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Visibility="{Binding IsStatusChangePanelVisible,
                           Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#88000000" Panel.ZIndex="20">
            <Border Width="420" Background="White" CornerRadius="8" Padding="28"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Змінити статус заяви" Style="{StaticResource SectionHeader}" FontSize="18"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Новий статус"/>
                    <ComboBox ItemsSource="{Binding AllStatuses}"
                              SelectedItem="{Binding NewStatus}"
                              Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Converter={StaticResource StatusToColorConverter}}"
                                        CornerRadius="3" Padding="6,3">
                                    <TextBlock Text="{Binding Converter={StaticResource StatusToStringConverter}}"
                                               Foreground="{Binding Converter={StaticResource StatusToForegroundConverter}}"
                                               FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Коментар"/>
                    <TextBox Text="{Binding StatusChangeComment, UpdateSourceTrigger=PropertyChanged}"
                             Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                             Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Скасувати" Style="{StaticResource GrayButton}"
                                Command="{Binding CancelStatusChangeCommand}" Margin="0,0,10,0"/>
                        <Button Content="✓ Застосувати" Style="{StaticResource SuccessButton}"
                                Command="{Binding ApplyStatusChangeCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Add/Edit overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Visibility="{Binding IsEditPanelVisible,
                           Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#88000000" Panel.ZIndex="20">
            <Border Width="520" Background="White" CornerRadius="8" Padding="28"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Заява" Style="{StaticResource SectionHeader}" FontSize="18"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FormLabel}" Text="Абітурієнт *"/>
                            <ComboBox ItemsSource="{Binding Applicants}"
                                      SelectedValue="{Binding EditingApplication.ApplicantId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="FullName"
                                      Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Спеціальність *"/>
                            <ComboBox ItemsSource="{Binding Specialties}"
                                      SelectedValue="{Binding EditingApplication.SpecialtyId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Форма навчання"/>
                            <ComboBox ItemsSource="{Binding AllForms}"
                                      SelectedItem="{Binding EditingApplication.FormOfEducation}"
                                      Margin="0,0,0,12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource FormToStringConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Основа навчання"/>
                            <ComboBox ItemsSource="{Binding AllBases}"
                                      SelectedItem="{Binding EditingApplication.EducationBasis}"
                                      Margin="0,0,0,12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource BasisToStringConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Style="{StaticResource FormLabel}" Text="Пріоритет *"/>
                            <TextBox Text="{Binding EditingApplication.Priority, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Конкурсний бал"/>
                            <TextBox Text="{Binding EditingApplication.CompetitiveScore, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Примітки"/>
                            <TextBox Text="{Binding EditingApplication.Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                     Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Скасувати" Style="{StaticResource GrayButton}"
                                Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                        <Button Content="💾 Зберегти" Style="{StaticResource SuccessButton}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
