<UserControl x:Class="AdmissionSystem.Views.RankingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Specialty selector + actions -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Спеціальність:"
                           VerticalAlignment="Center" FontWeight="SemiBold"
                           Margin="0,0,12,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Specialties}"
                          SelectedItem="{Binding SelectedSpecialty}"
                          DisplayMemberPath="Name"/>

                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>

                <Button Grid.Column="3" Content="🔄 Оновити рейтинг"
                        Style="{StaticResource GrayButton}"
                        Command="{Binding RefreshRankingCommand}"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="⚡ Перерахувати рейтинг"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RecalculateCommand}"/>
            </Grid>
        </Border>

        <!-- Legend -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Легенда:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Border Background="{StaticResource SuccessBrush}" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                    <TextBlock Text="Бюджет" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#64B5F6" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                    <TextBlock Text="Контракт" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <Border Background="{StaticResource WarningBrush}" CornerRadius="4" Padding="10,4">
                    <TextBlock Text="Резерв" Foreground="Black" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Ranking table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Ranking}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Recommendation}" Value="Бюджет">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Recommendation}" Value="Контракт">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Recommendation}" Value="Резерв">
                                <Setter Property="Background" Value="#FFFDE7"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Місце" Binding="{Binding Rank}" Width="65">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ПІБ абітурієнта" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Конкурсний бал"
                                        Binding="{Binding CompetitiveScore, StringFormat=F2}"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Пріоритет" Binding="{Binding Priority}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Рекомендація" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Recommendation,
                                                    Converter={StaticResource RecommendationToColorConverter}}"
                                        CornerRadius="4" Padding="8,4" Margin="4,2">
                                    <TextBlock Text="{Binding Recommendation}"
                                               Foreground="White" FontWeight="SemiBold"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Статус" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Application.CurrentStatus,
                                                    Converter={StaticResource StatusToColorConverter}}"
                                        CornerRadius="4" Padding="6,3" Margin="2">
                                    <TextBlock Text="{Binding Application.CurrentStatus,
                                                      Converter={StaticResource StatusToStringConverter}}"
                                               Foreground="{Binding Application.CurrentStatus,
                                                            Converter={StaticResource StatusToForegroundConverter}}"
                                               FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
