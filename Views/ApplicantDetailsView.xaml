<UserControl x:Class="AdmissionSystem.Views.ApplicantDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Card -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Applicant.FullName}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="📅 " FontSize="13"/>
                        <TextBlock Text="{Binding Applicant.DateOfBirth, StringFormat='Дата народження: {0:dd.MM.yyyy}'}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,0"/>
                        <TextBlock Text="📧 " FontSize="13"/>
                        <TextBlock Text="{Binding Applicant.Email}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,0"/>
                        <TextBlock Text="📞 " FontSize="13"/>
                        <TextBlock Text="{Binding Applicant.Phone}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Applicant.Address}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding Applicant.AverageGrade, StringFormat='Середній бал: {0:F2}'}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="← Назад"
                        Style="{StaticResource GrayButton}"
                        Click="BackButton_Click" VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1">
            <!-- Tab: Applications -->
            <TabItem Header="📋 Заяви">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="+ Додати заяву"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddApplicationCommand}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding Applications}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Priority}" Width="40"/>
                                <DataGridTextColumn Header="Спеціальність"
                                                    Binding="{Binding Specialty.Name}" Width="*"/>
                                <DataGridTextColumn Header="Код"
                                                    Binding="{Binding Specialty.Code}" Width="70"/>
                                <DataGridTextColumn Header="Форма"
                                                    Binding="{Binding FormOfEducation,
                                                              Converter={StaticResource FormToStringConverter}}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="Основа"
                                                    Binding="{Binding EducationBasis,
                                                              Converter={StaticResource BasisToStringConverter}}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="Конкурсний бал"
                                                    Binding="{Binding CompetitiveScore, StringFormat=F2}"
                                                    Width="120"/>
                                <DataGridTemplateColumn Header="Статус" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CurrentStatus,
                                                                Converter={StaticResource StatusToColorConverter}}"
                                                    CornerRadius="4" Padding="8,3" Margin="2">
                                                <TextBlock Text="{Binding CurrentStatus,
                                                                  Converter={StaticResource StatusToStringConverter}}"
                                                           Foreground="{Binding CurrentStatus,
                                                                        Converter={StaticResource StatusToForegroundConverter}}"
                                                           FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Дата подання"
                                                    Binding="{Binding SubmissionDate, StringFormat=dd.MM.yyyy}"
                                                    Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab: Documents -->
            <TabItem Header="📄 Документи">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="0">
                    <DataGrid ItemsSource="{Binding Documents}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тип документа"
                                                Binding="{Binding DocumentType,
                                                          Converter={StaticResource DocTypeToStringConverter}}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Файл" Binding="{Binding FileName}" Width="*"/>
                            <DataGridTemplateColumn Header="Подано" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsProvided, Converter={StaticResource BoolToVerifiedTextConverter}}"
                                                   Foreground="{Binding IsProvided, Converter={StaticResource BoolToVerifiedColorConverter}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Перевірено" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsVerified, Converter={StaticResource BoolToVerifiedTextConverter}}"
                                                   Foreground="{Binding IsVerified, Converter={StaticResource BoolToVerifiedColorConverter}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Дія" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Змінити статус"
                                                Style="{StaticResource PrimaryButton}"
                                                FontSize="11" Padding="8,4"
                                                Command="{Binding DataContext.VerifyDocumentCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Коментар" Binding="{Binding Comment}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Add application overlay -->
        <Border Grid.Row="1"
                Visibility="{Binding IsAddApplicationVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="#88000000" Panel.ZIndex="10">
            <Border Width="480" Background="White" CornerRadius="8" Padding="28"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Нова заява" Style="{StaticResource SectionHeader}" FontSize="18"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Спеціальність *"/>
                    <ComboBox ItemsSource="{Binding Specialties}"
                              SelectedValue="{Binding NewApplication.SpecialtyId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Форма навчання"/>
                    <ComboBox SelectedValue="{Binding NewApplication.FormOfEducation}"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="Денна" Tag="0"/>
                        <ComboBoxItem Content="Заочна" Tag="1"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Основа навчання"/>
                    <ComboBox SelectedValue="{Binding NewApplication.EducationBasis}"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="Бюджет"/>
                        <ComboBoxItem Content="Контракт"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Пріоритет"/>
                    <TextBox Text="{Binding NewApplication.Priority, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Конкурсний бал"/>
                    <TextBox Text="{Binding NewApplication.CompetitiveScore, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Примітки"/>
                    <TextBox Text="{Binding NewApplication.Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Скасувати" Style="{StaticResource GrayButton}"
                                Command="{Binding CancelApplicationCommand}" Margin="0,0,10,0"/>
                        <Button Content="💾 Зберегти" Style="{StaticResource SuccessButton}"
                                Command="{Binding SaveApplicationCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
