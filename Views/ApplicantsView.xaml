<UserControl x:Class="AdmissionSystem.Views.ApplicantsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main list panel -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" Margin="10,0,4,0"
                                       VerticalAlignment="Center" FontSize="14"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="4,7"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1" Content="+ Додати"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="✏ Редагувати"
                            Style="{StaticResource GrayButton}"
                            Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="🗑 Видалити"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteCommand}"/>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Applicants}"
                          SelectedItem="{Binding SelectedApplicant}"
                          MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Прізвище" Binding="{Binding LastName}" Width="140"/>
                        <DataGridTextColumn Header="Ім'я" Binding="{Binding FirstName}" Width="120"/>
                        <DataGridTextColumn Header="По батькові" Binding="{Binding MiddleName}" Width="140"/>
                        <DataGridTextColumn Header="Дата народження"
                                            Binding="{Binding DateOfBirth, StringFormat=dd.MM.yyyy}" Width="130"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                        <DataGridTextColumn Header="Середній бал"
                                            Binding="{Binding AverageGrade, StringFormat=F2}" Width="110"/>
                        <DataGridTextColumn Header="Дата реєстрації"
                                            Binding="{Binding RegistrationDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Edit/Add panel -->
        <Border Grid.Column="1"
                Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="380" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <TextBlock Style="{StaticResource SectionHeader}"
                               Text="{Binding EditingApplicant.Id,
                                      Converter={StaticResource ActiveToStringConverter},
                                      FallbackValue='Новий абітурієнт'}"/>

                    <!-- Form fields -->
                    <TextBlock Style="{StaticResource FormLabel}" Text="Прізвище *"/>
                    <TextBox Text="{Binding EditingApplicant.LastName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Ім'я *"/>
                    <TextBox Text="{Binding EditingApplicant.FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="По батькові"/>
                    <TextBox Text="{Binding EditingApplicant.MiddleName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Дата народження"/>
                    <DatePicker SelectedDate="{Binding EditingApplicant.DateOfBirth}"
                                Margin="0,0,0,12" FontFamily="Segoe UI" FontSize="13"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Стать"/>
                    <ComboBox SelectedValue="{Binding EditingApplicant.Gender}" 
          SelectedValuePath="Content">
                        <ComboBoxItem>Чоловіча</ComboBoxItem>
                        <ComboBoxItem>Жіноча</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Телефон"/>
                    <TextBox Text="{Binding EditingApplicant.Phone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Email"/>
                    <TextBox Text="{Binding EditingApplicant.Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Адреса"/>
                    <TextBox Text="{Binding EditingApplicant.Address, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" TextWrapping="Wrap" Height="60"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Серія/номер документа"/>
                    <TextBox Text="{Binding EditingApplicant.DocumentSeriesNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="ІПН"/>
                    <TextBox Text="{Binding EditingApplicant.TaxCode, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Середній бал документа про освіту"/>
                    <TextBox Text="{Binding EditingApplicant.AverageGrade, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Скасувати" Style="{StaticResource GrayButton}"
                                Command="{Binding CancelEditCommand}" Margin="0,0,10,0"/>
                        <Button Content="💾 Зберегти" Style="{StaticResource SuccessButton}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
