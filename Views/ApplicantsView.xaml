<UserControl x:Class="AdmissionSystem.Views.ApplicantsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextElement.FontFamily="Segoe UI"
             TextElement.FontSize="14"
             TextElement.Foreground="#0F172A"
             Background="#F8FAFC">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TextMain" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#4F46E5"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#4338CA"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerHover" Color="#DC2626"/>

        <Style x:Key="PremiumTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" 
                                          VerticalAlignment="Center" Focusable="false" 
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter Property="Padding" Value="13,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="0.5" CenterY="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" BasedOn="{StaticResource PremiumButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnSecondary" BasedOn="{StaticResource PremiumButton}" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnDanger" BasedOn="{StaticResource PremiumButton}" TargetType="Button">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FECACA"/>
                    <Setter Property="Foreground" Value="{StaticResource DangerHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="56"/>
            <Setter Property="ColumnHeaderHeight" Value="50"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryHover}"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="2,16,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource BorderColor}" 
                        Height="42" Width="320" HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" 
                                   Foreground="{StaticResource TextMuted}" FontSize="15" 
                                   VerticalAlignment="Center" Margin="14,0,10,0"/>

                        <TextBlock Grid.Column="1" Text="Пошук..." 
                                   Foreground="#94A3B8" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox x:Name="SearchBox" Grid.Column="1" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" 
                                 VerticalContentAlignment="Center" FontSize="14" CaretBrush="{StaticResource PrimaryColor}"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource BtnPrimary}" Command="{Binding AddCommand}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
                            <TextBlock Text="Додати" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnSecondary}" Command="{Binding EditCommand}" Margin="0,0,12,0" ToolTip="Редагувати">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" FontSize="16"/>
                    </Button>

                    <Button Style="{StaticResource BtnDanger}" Command="{Binding DeleteCommand}" ToolTip="Видалити">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="#000000" Direction="270"/>
                </Border.Effect>

                <DataGrid ItemsSource="{Binding Applicants}" SelectedItem="{Binding SelectedApplicant}" MouseDoubleClick="DataGrid_MouseDoubleClick" Margin="0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>

                        <DataGridTextColumn Header="ПРІЗВИЩЕ" Binding="{Binding LastName}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="ІМ'Я" Binding="{Binding FirstName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="ПО БАТЬКОВІ" Binding="{Binding MiddleName}" Width="*" IsReadOnly="True"/>

                        <DataGridTextColumn Header="ДАТА НАРОДЖ." Binding="{Binding DateOfBirth, StringFormat='{}{0:dd.MM.yyyy}'}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="ТЕЛЕФОН" Binding="{Binding Phone}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="180" IsReadOnly="True" Foreground="{StaticResource TextMuted}"/>
                        <DataGridTextColumn Header="БАЛ" Binding="{Binding AverageGrade, StringFormat='{}{0:F2}'}" Width="80" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="400" Background="{StaticResource CardBackground}" CornerRadius="16" Margin="32,0,0,0"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.06" Color="#000000" Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="24,20">
                    <TextBlock Text="Редагування запису" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="Прізвище *" Margin="2,8,0,6"/>
                        <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.LastName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Ім'я *"/>
                        <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.FirstName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="По батькові"/>
                        <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.MiddleName, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FormLabel}" Text="Дата народж." Margin="2,0,0,6"/>
                                <DatePicker SelectedDate="{Binding EditingApplicant.DateOfBirth}" Height="42" FontSize="14" Padding="10,8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FormLabel}" Text="Стать" Margin="2,0,0,6"/>
                                <ComboBox SelectedValue="{Binding EditingApplicant.Gender}" SelectedValuePath="Content" Height="42" FontSize="14" Padding="12,10">
                                    <ComboBoxItem>Чоловіча</ComboBoxItem>
                                    <ComboBoxItem>Жіноча</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Телефон"/>
                        <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.Phone, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Електронна пошта"/>
                        <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.Email, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FormLabel}" Text="Серія/№ док-ту" Margin="2,0,0,6"/>
                                <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.DocumentSeriesNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FormLabel}" Text="Середній бал" Margin="2,0,0,6"/>
                                <TextBox Style="{StaticResource PremiumTextBox}" Text="{Binding EditingApplicant.AverageGrade, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,16,16" Padding="24,16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Скасувати" Style="{StaticResource BtnSecondary}" Command="{Binding CancelEditCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Style="{StaticResource BtnPrimary}" Command="{Binding SaveCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>