<UserControl x:Class="AdmissionSystem.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="20,16" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#1A000000" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding RefreshCommand}" Cursor="Hand" BorderThickness="0" Background="Transparent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="#2563EB" CornerRadius="8" Padding="16,10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔄" Foreground="White" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Оновити статистику" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- Summary stat cards -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Disabled">
            <WrapPanel Margin="20,16,20,0" Orientation="Horizontal">

                <!-- Total Applicants -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="👤" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalApplicants}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        <TextBlock Text="Абітурієнтів"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Total Applications -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalApplications}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        <TextBlock Text="Заяв всього"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Budget recommended -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,12"
                        BorderBrush="#A5D6A7">
                    <StackPanel>
                        <TextBlock Text="🎓" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BudgetRecommended}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        <TextBlock Text="Рекомендовано (бюджет)"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="130"/>
                    </StackPanel>
                </Border>

                <!-- Contract recommended -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,12"
                        BorderBrush="#90CAF9">
                    <StackPanel>
                        <TextBlock Text="📝" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ContractRecommended}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#1E88E5"
                                   HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        <TextBlock Text="Рекомендовано (контракт)"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="130"/>
                    </StackPanel>
                </Border>

                <!-- Reserved -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,0,12"
                        BorderBrush="#FFE082">
                    <StackPanel>
                        <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Reserved}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        <TextBlock Text="В резерві"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <!-- Tables row -->
        <Grid Grid.Row="2" Margin="20,12,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- By specialty -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E3F2FD" Padding="16,12"
                            CornerRadius="8,8,0,0">
                        <TextBlock Text="Заяви по спеціальностях"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding BySpecialty}"
                              RowHeight="34">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Спеціальність"
                                                Binding="{Binding SpecialtyName}" Width="*"/>
                            <DataGridTextColumn Header="Кількість заяв"
                                                Binding="{Binding Count}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- By status -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E3F2FD" Padding="16,12"
                            CornerRadius="8,8,0,0">
                        <TextBlock Text="Заяви по статусах"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ByStatus}"
                              RowHeight="34">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Статус" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status,
                                                            Converter={StaticResource StatusToColorConverter}}"
                                                CornerRadius="4" Padding="8,3" Margin="4,3">
                                            <TextBlock Text="{Binding StatusName}"
                                                       Foreground="{Binding Status,
                                                                    Converter={StaticResource StatusToForegroundConverter}}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Кількість"
                                                Binding="{Binding Count}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="15"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
